generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Product {
  SPONSORSHIP
  ADS
  NEWS
  PROMO
  GIVEAWAY
}

enum BookingStatus {
  DRAFT_RESERVED
  SUBMITTED
  CANCELLED
  PUBLISHED
}

enum ReservationSource {
  DRAFT_HOLD
  WOOCOMMERCE_PAID_ORDER
  TEST_DATA
  ADMIN_MANUAL
  LEGACY
}

enum SubmissionDraftStatus {
  DRAFT
  SUBMITTED
  APPROVED
  CANCELLED
}

enum AdminRole {
  SUPER_ADMIN
  CONTENT_ADMIN
  OPS_ADMIN
  PUBLISHER
  CLIENT_PRO
}

enum OrderPaymentStatus {
  PAID
  PENDING
  FAILED
  REFUNDED
}

enum EditorialStatus {
  SUBMITTED
  UNDER_REVIEW
  CHANGES_REQUESTED
  APPROVED
  REJECTED
}

enum PublicationStatus {
  NOT_SCHEDULED
  SCHEDULED
  PUBLISHED
  ARCHIVED
}

model Booking {
  id            String   @id @default(cuid())
  product       Product
  groupId       String?
  startsAtUtc   DateTime?
  endsAtUtc     DateTime?
  monthKey      String?
  weekKey       String?
  status        BookingStatus @default(SUBMITTED)
  reservationSource ReservationSource @default(LEGACY)
  reservationLocked Boolean @default(false)
  reservedByOrderId String?
  linkedOrderId String?
  expiresAt     DateTime?
  companyName   String
  customerEmail String
  orderRef      String
  internalNote  String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  submissionDrafts SubmissionDraft[]

  @@unique([monthKey])
  @@index([groupId])
  @@index([weekKey])
  @@index([startsAtUtc])
  @@index([status, expiresAt])
  @@index([reservedByOrderId])
  @@index([reservationLocked, reservationSource])
  @@index([linkedOrderId])
}

model SubmissionDraft {
  id            String @id @default(cuid())
  orderId       String @unique
  orderKey      String
  email         String
  product       Product
  durationWeeks Int?
  status        SubmissionDraftStatus @default(DRAFT)
  title         String?
  body          String?
  bookingId     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  booking       Booking? @relation(fields: [bookingId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([product])
}

model SubmitFormSubmission {
  id                  String   @id @default(cuid())
  tokenHash           String   @unique
  linkedOrderId       String?
  orderNumber         String?
  productKey          String
  productType         String
  companyName         String
  contactEmail        String
  websiteUrl          String
  targetUrl           String
  adFormat            String
  startDate           DateTime
  notes               String?
  bannerImageName     String
  bannerImageMimeType String
  bannerImageSize     Int
  bannerImageData     Bytes
  reservationMonthKey String?
  reservationWeekKey  String?
  reservationStartsAt DateTime?
  orderContextJson    Json?
  formDataJson        Json
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  ops                 SubmissionOps?
  auditEvents         SubmissionAuditEvent[]

  @@index([linkedOrderId])
  @@index([orderNumber])
  @@index([productKey])
  @@index([productType])
  @@index([contactEmail])
  @@index([companyName])
  @@index([createdAt])
}

model SubmissionOps {
  id                  String            @id @default(cuid())
  submissionId        String            @unique
  orderPaymentStatus  OrderPaymentStatus @default(PAID)
  editorialStatus     EditorialStatus    @default(SUBMITTED)
  publicationStatus   PublicationStatus  @default(NOT_SCHEDULED)
  reviewerAssignee    String?
  clientVisibleNote   String?
  internalNote        String?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  submission          SubmitFormSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@index([editorialStatus])
  @@index([publicationStatus])
  @@index([orderPaymentStatus])
  @@index([reviewerAssignee])
  @@index([updatedAt])
}

model SubmissionAuditEvent {
  id              String    @id @default(cuid())
  submissionId    String
  actorRole       AdminRole
  actorIdentifier String?
  eventType       String
  fieldName       String?
  fromValue       String?
  toValue         String?
  comment         String?
  createdAt       DateTime  @default(now())

  submission      SubmitFormSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@index([submissionId, createdAt])
}
